# ── Secrets & env files ──
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example
deployment/env/.env.production

# ── Dependencies ──
node_modules/
**/node_modules/

# ── Build output ──
dist/
dist-ssr/
**/dist/
backend/dist/
frontend/dist/
*.tsbuildinfo

# ── Logs ──
logs/
*.log
npm-debug.log*

# ── Backups & database dumps ──
backups/
*.sql.gz
*.sql.zip

# ── Archives ──
*.zip

# ── Docker volumes ──
mysql_data/
redis_data/

# ── OS files ──
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / Editor ──
.vscode/*
!.vscode/extensions.json
.idea/
*.sw?

# ── Coverage ──
coverage/
*.lcov
.nyc_output/

# ── Uploads (runtime data, never commit) ──
backend/uploads/*
!backend/uploads/.gitkeep

# ── Runtime temp ──
backend/tmp/*

# ── Test artifacts ──
test-results/
playwright-report/
blob-report/
playwright/.cache/
