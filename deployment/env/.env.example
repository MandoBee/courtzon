# ==============================================================================
# CourtZon-V3 — Complete Environment Variables Template
# Copy this file to your .env and fill in real values. NEVER commit secrets.
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# Common / General
# ──────────────────────────────────────────────────────────────────────────────

# Application environment: development | test | production
NODE_ENV=development

# Logging level: debug | info | warn | error (production default: info)
LOG_LEVEL=debug

# ──────────────────────────────────────────────────────────────────────────────
# Database (MySQL)
# ──────────────────────────────────────────────────────────────────────────────

# MySQL host (use service name "mysql" inside Docker Compose)
DB_HOST=localhost

# MySQL server port (default: 3306)
DB_PORT=3306

# Database name
DB_NAME=courtzon_v2

# Backend application database user (least-privilege, see setup-db-users.sql)
DB_USER=courtzon_app

# Database user password
DB_PASSWORD=your-db-password

# ──────────────────────────────────────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────────────────────────────────────

# Redis host (use service name "redis" inside Docker Compose)
REDIS_HOST=localhost

# Redis server port (default: 6379)
REDIS_PORT=6379

# Redis password (leave empty if no password)
REDIS_PASSWORD=

# Redis database index (0-15)
REDIS_DB=0

# ──────────────────────────────────────────────────────────────────────────────
# Backend (Node.js / Fastify)
# ──────────────────────────────────────────────────────────────────────────────

# Backend server port (default: 3000)
PORT=3000

# Public URL of the backend (used for CORS, redirects, webhook callbacks)
APP_URL=http://localhost:5173

# Webhook base URL (for Paymob callbacks; defaults to APP_URL if not set)
# WEBHOOK_BASE_URL=https://api.courtzon.com

# Comma-separated list of allowed CORS origins
# CORS_ORIGINS=https://courtzon.com,https://admin.courtzon.com

# Session signing secret (REQUIRED in production, min 32 characters)
SESSION_SECRET=change-me-to-a-random-secret-at-least-32-chars

# JWT signing secret (falls back to SESSION_SECRET if not set)
# JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Enable Swagger API docs at /docs (default: true in dev, false in production)
# ENABLE_API_DOCS=true

# Set to "true" to relax rate limits (dev only, do NOT use in production)
# RELAX_RATE_LIMIT=false

# Super admin email for initial setup (optional, seeded in dev)
# SUPER_ADMIN_EMAIL=admin@courtzon.com

# Super admin password for initial setup (optional, seeded in dev)
# SUPER_ADMIN_PASSWORD=your-admin-password

# ──────────────────────────────────────────────────────────────────────────────
# Storage (File Uploads)
# ──────────────────────────────────────────────────────────────────────────────

# Storage provider: local | s3 | r2 (default: local)
STORAGE_PROVIDER=local

# S3-compatible endpoint URL (required if STORAGE_PROVIDER is s3 or r2)
# S3_ENDPOINT=https://your-s3-endpoint.com

# S3 bucket name
# S3_BUCKET=courtzon-uploads

# S3 access key
# S3_ACCESS_KEY=your-s3-access-key

# S3 secret key
# S3_SECRET_KEY=your-s3-secret-key

# S3 region (default: auto)
# S3_REGION=auto

# Public URL prefix for uploaded files (defaults to S3_ENDPOINT/bucket)
# S3_PUBLIC_URL=https://uploads.courtzon.com

# ──────────────────────────────────────────────────────────────────────────────
# Payment Gateway (Paymob)
# ──────────────────────────────────────────────────────────────────────────────

# Payment provider: mock | paymob | fawry (default: mock; must NOT be mock in production)
PAYMENT_GATEWAY_PROVIDER=mock

# Paymob Accept API key (for refunds / transactions)
# PAYMOB_API_KEY=ZXlK...your-api-key

# Paymob Secret key (Intention API authentication)
# PAYMOB_SECRET=sk_your-secret-key

# Paymob Public key (Unified Checkout URL generation)
# PAYMOB_PUBLIC_KEY=pk_your-public-key

# Paymob Merchant / Integration ID
# PAYMOB_MERCHANT_ID=123456789

# Paymob HMAC secret (webhook signature verification)
# PAYMOB_HMAC_SECRET=your-hmac-secret

# Paymob sandbox mode: true (test) | false (live)
# PAYMOB_SANDBOX=true

# ──────────────────────────────────────────────────────────────────────────────
# Email (SMTP — optional, defaults to log-only)
# ──────────────────────────────────────────────────────────────────────────────

# Mail transport: log | smtp (log = print to console; smtp = send real emails)
# MAIL_TRANSPORT=smtp

# SMTP host
# MAIL_HOST=smtp.example.com

# SMTP port (common: 25, 465, 587)
# MAIL_PORT=587

# SMTP username
# MAIL_USER=noreply@courtzon.com

# SMTP password
# MAIL_PASS=your-smtp-password

# From address for outgoing emails
# MAIL_FROM=CourtZon <noreply@courtzon.com>

# ──────────────────────────────────────────────────────────────────────────────
# Frontend (Vite)
# ──────────────────────────────────────────────────────────────────────────────

# Backend API URL for the browser (empty = proxy through Vite dev server)
VITE_API_URL=http://localhost:3000

# Paymob public key (browser-accessible, used by Pixel SDK)
# VITE_PAYMOB_PUBLIC_KEY=pk_test_your-public-key

# ──────────────────────────────────────────────────────────────────────────────
# Docker Compose (MySQL container)
# ──────────────────────────────────────────────────────────────────────────────

# MySQL root password (Docker Compose only, NOT used by the backend directly)
MYSQL_ROOT_PASSWORD=your-mysql-root-password

# MySQL database name (Docker Compose only)
MYSQL_DATABASE=courtzon_v2

# Host port to publish MySQL (avoid conflict with local MySQL on 3306)
MYSQL_PUBLISH_PORT=3307

# MySQL user (Docker Compose dev compose only)
# MYSQL_USER=app_user

# MySQL password (Docker Compose dev compose only)
# MYSQL_PASSWORD=change-me

# Host port to publish Redis (Docker Compose only)
# REDIS_PUBLISH_PORT=6379

# Host port to publish frontend Nginx (Docker Compose only)
FRONTEND_PORT=5173

# ──────────────────────────────────────────────────────────────────────────────
# Monitoring & Observability
# ──────────────────────────────────────────────────────────────────────────────

# Bearer token for GET /metrics endpoint (Prometheus scrape, optional)
# METRICS_TOKEN=your-metrics-token

# Grafana admin password (docker-compose.monitoring.yml only)
# GRAFANA_PASSWORD=admin

# ──────────────────────────────────────────────────────────────────────────────
# Backup & Security
# ──────────────────────────────────────────────────────────────────────────────

# AES-256 encryption key for database backups (32 bytes = 64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# BACKUP_ENCRYPTION_KEY=your-64-char-hex-key
