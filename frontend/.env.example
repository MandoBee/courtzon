# Frontend Environment Variables
# VITE_API_URL is the backend URL
# Leave empty to proxy through Vite dev server
VITE_API_URL=

# Paymob public key for Pixel SDK (browser-accessible)
VITE_PAYMOB_PUBLIC_KEY=pk_test_...

# Coaching feature flags (slice-level)
VITE_FEATURE_COACHING_SLICE0_ENABLED=true
VITE_FEATURE_COACHING_SLICE1_ENABLED=false
VITE_FEATURE_COACHING_SLICE2_ENABLED=false
VITE_FEATURE_COACHING_SLICE3_ENABLED=false
VITE_FEATURE_COACHING_SLICE4_ENABLED=false
VITE_FEATURE_COACHING_SLICE5_ENABLED=false
VITE_FEATURE_COACHING_SLICE6_ENABLED=false
VITE_FEATURE_COACHING_SLICE7_ENABLED=false
VITE_FEATURE_COACHING_SLICE8_ENABLED=false
VITE_FEATURE_COACHING_SLICE9_ENABLED=false
VITE_FEATURE_COACHING_SLICE10_ENABLED=false

# Coaching feature flags (feature-level)
VITE_FEATURE_COACHING_BOOKING_ENABLED=false
VITE_FEATURE_COACHING_PROMO_CODES_ENABLED=false
VITE_FEATURE_COACHING_ONBOARDING_ENABLED=false
VITE_FEATURE_COACHING_VIDEO_INTRO_ENABLED=false
