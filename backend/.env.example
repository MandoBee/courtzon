# Backend Environment Variables (Example)
# Copy to .env and fill in real values. NEVER commit secrets.

NODE_ENV=development
PORT=3000

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

DB_HOST=localhost
DB_PORT=3306
DB_USER=app_user
