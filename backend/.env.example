# Backend Environment Variables (Example)
# Copy to .env and fill in real values. NEVER commit secrets.

NODE_ENV=development
PORT=3000

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

DB_HOST=localhost
DB_PORT=3306
DB_USER=app_user
DB_PASSWORD=change-me
DB_NAME=courtzon_v2

# APP_URL=https://your-tunnel.trycloudflare.com
# WEBHOOK_BASE_URL=https://your-webhook-tunnel.trycloudflare.com

# ── Paymob (card/online payments) ──
# Required for production card payment flow.
# Get sandbox keys from https://accept.paymobsandbox.com → Developers → API Keys
# For production, switch to https://accept.paymob.com
PAYMENT_GATEWAY_PROVIDER=paymob
# PAYMOB_API_KEY=ZXlKaGJHY2lPaUpJVXpVeE1pSXNJblI1Y0NJNklrcFhWQ0o5...
# PAYMOB_SECRET=sk_test_...
# PAYMOB_PUBLIC_KEY=pk_test_...
# PAYMOB_MERCHANT_ID=1234567
# PAYMOB_HMAC_SECRET=your_hmac_secret_here
# PAYMOB_SANDBOX=true
# WEBHOOK_BASE_URL=https://your-domain.com
