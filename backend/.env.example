# Backend Environment Variables (Example)
# Copy to .env and fill in real values. NEVER commit secrets.

NODE_ENV=development
PORT=3000

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

DB_HOST=localhost
DB_PORT=3306
DB_USER=app_user
DB_PASSWORD=change-me
DB_NAME=courtzon_v2

# APP_URL=https://your-tunnel.trycloudflare.com
# WEBHOOK_BASE_URL=https://your-webhook-tunnel.trycloudflare.com

# ── Paymob (card/online payments) ──
# Required for production card payment flow.
# API keys from https://accept.paymob.com → Developers → API Keys
# Test keys start with egy_sk_test_ / egy_pk_test_ (sandbox)
# Live keys start with egy_sk_live_ / egy_pk_live_ (production)
# Both environments use the same API URL: https://accept.paymob.com
PAYMENT_GATEWAY_PROVIDER=paymob
# PAYMOB_API_KEY=ZXlKaGJHY2lPaUpJVXpVeE1pSXNJblI1Y0NJNklrcFhWQ0o5...
# PAYMOB_SECRET=sk_test_...
# PAYMOB_PUBLIC_KEY=pk_test_...
# PAYMOB_MERCHANT_ID=1234567
# PAYMOB_HMAC_SECRET=your_hmac_secret_here
# PAYMOB_SANDBOX=true
# WEBHOOK_BASE_URL=https://your-domain.com

# ── Booking Intent Retention (days, used by cleanup_booking_intents cron) ──
# INTENT_RETENTION_FULFILLED_DAYS=90
# INTENT_RETENTION_TERMINAL_DAYS=30

# ── Payment retry (frontend-driven) ──
# PAYMENT_MAX_RETRY_ATTEMPTS=3

# ── Session Management ──
# SESSION_ACCESS_TOKEN_EXPIRY=15m     # Access token lifetime (m=minutes, h=hours, d=days)
# SESSION_REFRESH_TOKEN_EXPIRY=30d    # Refresh token lifetime with Remember Me
# SESSION_REFRESH_TOKEN_SESSION_EXPIRY=1d  # Refresh token lifetime without Remember Me
# SESSION_MAX_DEVICES=5               # Max concurrent sessions per user

# ── Deployment metadata (optional, used by health endpoints) ──
# These are set by Docker build args; provide manually for non-Docker environments.
# GIT_COMMIT=
# APP_VERSION=
# EXPECTED_MIGRATION=
# BUILD_TIME=
