{
  "name": "courtzon-v2-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "node scripts/migrate.js",
    "db:fresh": "node scripts/migrate.js --fresh",
    "db:seed": "node scripts/seed.js",
    "db:backup": "bash ../scripts/backup.sh",
    "db:restore": "bash ../scripts/restore.sh",
    "db:status": "node scripts/migrate.js --status",
    "emergency-repair": "node scripts/emergency-repair.js",
    "bootstrap-admin": "node scripts/bootstrap-admin.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "test:int": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1058.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "bullmq": "^5.76.10",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "ioredis": "^5.8.2",
    "mysql2": "^3.22.3",
    "nodemailer": "^8.0.7",
    "pino": "^10.0.0",
    "pino-pretty": "^13.1.1",
    "prom-client": "^15.1.3",
    "sharp": "^0.34.5",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "@types/nodemailer": "^8.0.0",
    "@types/sharp": "^0.31.1",
    "testcontainers": "^11.4.0",
    "tsx": "^4.20.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
