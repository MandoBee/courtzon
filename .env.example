# ============================================================================
# CourtZon Environment Variables (Example)
# Copy to .env and fill in your values. NEVER commit real secrets.
# ============================================================================

# ── Database ──
DB_HOST=localhost
DB_PORT=3306
DB_NAME=courtzon_v2
DB_USER=app_user
DB_PASSWORD=change-me

# ── Docker MySQL (if using Docker database) ──
MYSQL_HOST=localhost
MYSQL_PORT=3306
# Host port when using Docker MySQL (avoids conflict with local MySQL on 3306)
MYSQL_PUBLISH_PORT=3307
MYSQL_DATABASE=courtzon_v2
MYSQL_USER=app_user
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── App ──
PORT=3000
FRONTEND_PORT=5173
NODE_ENV=development
APP_URL=http://localhost:5173

# ── Docker / observability (local stack) ──
# ENABLE_API_DOCS=true   # Swagger at /docs (omit in real production)
# METRICS_TOKEN=         # Optional Bearer token for GET /metrics (Prometheus scrape)
# GRAFANA_PASSWORD=admin # docker-compose.monitoring.yml

# ── Email (optional — defaults to log-only) ──
# MAIL_TRANSPORT=smtp
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USER=your@email.com
# MAIL_PASS=your-password
# MAIL_FROM=noreply@courtzon.com

# ── Storage ──
# STORAGE_PROVIDER=local     # local | s3 | r2
# S3_ENDPOINT=https://...
# S3_BUCKET=courtzon-uploads
# S3_ACCESS_KEY=...
# S3_SECRET_KEY=...
# S3_REGION=auto

# ── Paymob ──
# PAYMENT_GATEWAY_PROVIDER=mock | paymob
# PAYMOB_API_KEY=ZXlK...                          # Accept API key (for refunds)
# PAYMOB_SECRET=sk_...                             # Secret key (Intention API auth)
# PAYMOB_PUBLIC_KEY=pk_...                         # Public key (Unified Checkout URL)
# PAYMOB_MERCHANT_ID=5663993                       # Integration ID
# PAYMOB_HMAC_SECRET=...                           # Webhook HMAC secret
# PAYMOB_SANDBOX=true                              # true = test mode

# ── Security ──
# SESSION_SECRET=change-me-to-a-random-secret-at-least-32-chars
# JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
# CORS_ORIGINS=https://courtzon.com,https://admin.courtzon.com

# ============================================================================
# Production-Only Variables
# ============================================================================

# ── Production URLs (used for CORS, redirects, webhooks) ──
# FRONTEND_URL=https://www.courtzon.cloud
# APP_URL=https://api.courtzon.cloud

# ── Production logging ──
# LOG_LEVEL=info

# ── Backup encryption key (production only) ──
# BACKUP_ENCRYPTION_KEY=
