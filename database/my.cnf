# CourtZon MySQL 8 Production Configuration
# Deploy to: /etc/mysql/my.cnf or /etc/mysql/mysql.conf.d/courtzon.cnf
# For Hostinger KVM 2 (2 vCPU, 8 GB RAM, 100 GB NVMe)

[mysqld]
# ── Basic ──
port                    = 3306
bind-address            = 127.0.0.1
default-authentication-plugin = mysql_native_password
character-set-server    = utf8mb4
collation-server        = utf8mb4_unicode_ci

# ── InnoDB (tuned for 8 GB RAM) ──
innodb_buffer_pool_size = 1G
innodb_buffer_pool_instances = 1
innodb_log_file_size    = 256M
innodb_log_buffer_size  = 16M
innodb_flush_log_at_trx_commit = 1
innodb_flush_method     = O_DIRECT
innodb_file_per_table   = 1
innodb_io_capacity      = 2000
innodb_io_capacity_max  = 4000

# ── Connections ──
max_connections         = 100
max_user_connections    = 80
wait_timeout            = 60
interactive_timeout     = 120

# ── Binary Log (for point-in-time recovery + replication) ──
log_bin                 = /var/log/mysql/binlog/courtzon-bin
binlog_format           = ROW
binlog_expire_logs_seconds = 2592000
max_binlog_size         = 256M
binlog_row_image        = MINIMAL

# ── Slow Query Log ──
slow_query_log          = 1
slow_query_log_file     = /var/log/mysql/courtzon-slow.log
long_query_time         = 2
log_queries_not_using_indexes = 1

# ── Performance ──
tmp_table_size          = 64M
max_heap_table_size     = 64M
sort_buffer_size        = 4M
read_buffer_size        = 2M
join_buffer_size        = 4M
thread_cache_size       = 16
table_open_cache        = 2000
open_files_limit        = 65535

# ── Safety ──
sql_mode                = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION
max_allowed_packet      = 64M
group_concat_max_len    = 102400

# ── SSL/TLS (optional — enable for internal encryption) ──
# require_secure_transport = ON

[client]
default-character-set   = utf8mb4

[mysql]
default-character-set   = utf8mb4

[mysqldump]
single-transaction      = 1
routines                = 1
triggers                = 1
events                  = 1
default-character-set   = utf8mb4
max_allowed_packet      = 64M
